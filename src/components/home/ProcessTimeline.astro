---
import nl from '../../i18n/nl.json';
import Container from '../shared/Container.astro';
import MonoEyebrow from '../shared/MonoEyebrow.astro';

const t = nl.home.process;
---

<section class="py-24 md:py-32 reveal">
  <Container>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-12 mb-14 md:mb-16">
      <div>
        <MonoEyebrow text={t.eyebrow} tone="accent-hi" class="mb-5 block" />
        <h2 class="text-h2 font-medium" style="letter-spacing: var(--tracking-tight); line-height: 1.08;">
          <span class="block text-fg">{t.h2Line1}</span>
          <span class="block text-accent">{t.h2Line2}</span>
        </h2>
      </div>
      <div class="flex md:items-end">
        <p class="text-body text-fg-dim max-w-[52ch]">{t.lead}</p>
      </div>
    </div>

    <!-- Desktop: horizontal timeline -->
    <ol class="hidden md:grid grid-cols-4 gap-6 relative">
      {t.steps.map((step, idx) => (
        <li class="relative">
          {idx < t.steps.length - 1 && (
            <div class="absolute top-[9px] left-[calc(48px+16px)] right-[-12px] h-px bg-[var(--color-accent-line)]" aria-hidden="true"></div>
          )}
          <div class="flex items-center gap-3 mb-5">
            <span class="font-mono text-[14px] text-accent-hi">{step.number}</span>
            <span class="w-[6px] h-[6px] rounded-full bg-[var(--color-accent)]"></span>
          </div>
          <h3 class="text-[18px] font-medium text-fg mb-1" style="letter-spacing: var(--tracking-snug);">{step.title}</h3>
          <p class="font-mono text-[12px] text-fg-faint mb-3 uppercase tracking-[0.04em]">{step.duration}</p>
          <p class="text-[14px] text-fg-dim" style="line-height: 1.6;">{step.body}</p>
        </li>
      ))}
    </ol>

    <!-- Mobile: vertical stack with big faint numbers -->
    <ol class="md:hidden space-y-10">
      {t.steps.map((step) => (
        <li class="relative pl-1">
          <span
            aria-hidden="true"
            class="absolute -left-1 -top-6 font-mono text-[64px] leading-none text-accent/20 select-none pointer-events-none"
          >{step.number}</span>
          <div class="relative">
            <h3 class="text-[18px] font-medium text-fg mb-1" style="letter-spacing: var(--tracking-snug);">{step.title}</h3>
            <p class="font-mono text-[12px] text-fg-faint mb-2 uppercase tracking-[0.04em]">{step.duration}</p>
            <p class="text-[14px] text-fg-dim" style="line-height: 1.6;">{step.body}</p>
          </div>
        </li>
      ))}
    </ol>
  </Container>
</section>
