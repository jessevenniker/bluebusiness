---
import { getCurrentLocale } from '../../i18n/routes';
import { getContent } from '../../i18n/content';
import Container from '../shared/Container.astro';
import MonoEyebrow from '../shared/MonoEyebrow.astro';

const locale = getCurrentLocale(Astro.url.pathname);
const t = getContent(locale).home.process;
---

<section class="py-24 md:py-32 reveal">
  <Container>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-12 mb-14 md:mb-16">
      <div>
        <MonoEyebrow text={t.eyebrow} tone="accent-hi" class="mb-5 block" />
        <h2 class="text-h2 font-medium" style="letter-spacing: var(--tracking-tight); line-height: 1.08;">
          <span class="block text-fg">{t.h2Line1}</span>
          <span class="block text-accent">{t.h2Line2}</span>
        </h2>
      </div>
      <div class="flex md:items-end">
        <p class="text-body text-fg-dim max-w-[52ch]">{t.lead}</p>
      </div>
    </div>

    {/* Single responsive list — same DOM for mobile and desktop, only decorative
        elements toggle. Avoids duplicate content for crawlers and screen readers. */}
    <ol class="grid grid-cols-1 md:grid-cols-4 gap-10 md:gap-6 relative">
      {t.steps.map((step, idx) => (
        <li class="relative pl-1 md:pl-0">
          {/* Desktop: thin connector line between steps */}
          {idx < t.steps.length - 1 && (
            <div class="hidden md:block absolute top-[9px] left-[calc(48px+16px)] right-[-12px] h-px bg-[var(--color-accent-line)]" aria-hidden="true"></div>
          )}

          {/* Mobile: oversized faint number behind the title */}
          <span aria-hidden="true" class="md:hidden absolute -left-1 -top-6 font-mono text-[64px] leading-none text-accent/20 select-none pointer-events-none">
            {step.number}
          </span>

          {/* Desktop: small inline number + dot */}
          <div class="hidden md:flex items-center gap-3 mb-5">
            <span class="font-mono text-[14px] text-accent-hi">{step.number}</span>
            <span class="w-[6px] h-[6px] rounded-full bg-[var(--color-accent)]"></span>
          </div>

          <div class="relative">
            <h3 class="text-[18px] font-medium text-fg mb-1" style="letter-spacing: var(--tracking-snug);">{step.title}</h3>
            <p class="font-mono text-[12px] text-fg-faint mb-2 md:mb-3 uppercase tracking-[0.04em]">{step.duration}</p>
            <p class="text-[14px] text-fg-dim" style="line-height: 1.6;">{step.body}</p>
          </div>
        </li>
      ))}
    </ol>
  </Container>
</section>
