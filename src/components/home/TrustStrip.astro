---
import { getCurrentLocale } from '../../i18n/routes';
import { getContent } from '../../i18n/content';
import Container from '../shared/Container.astro';
import MonoEyebrow from '../shared/MonoEyebrow.astro';

const locale = getCurrentLocale(Astro.url.pathname);
const t = getContent(locale).home.trust;
---

<section class="py-20 md:py-24 border-y border-[var(--color-accent-line)] reveal">
  <Container>
    <div class="text-center mb-10 md:mb-12">
      <MonoEyebrow text={t.eyebrow} tone="accent-hi" class="mb-4 inline-block" />
      <p class="text-[16px] md:text-[18px] text-fg-dim max-w-[60ch] mx-auto" style="line-height: 1.6;">
        {t.text}
      </p>
    </div>

    <ul class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3 md:gap-4 max-w-[1100px] mx-auto" role="list">
      {t.logos.map((logo) => (
        <li class="logo-tile bg-white rounded-[14px] border border-[var(--color-border)] flex items-center justify-center min-h-[110px] md:min-h-[120px] p-5 transition-all duration-[240ms] hover:border-[var(--color-accent-line)]">
          <img
            src={logo.src}
            alt={logo.alt}
            class="max-h-[60px] md:max-h-[68px] max-w-full object-contain"
            loading="lazy"
            decoding="async"
          />
        </li>
      ))}
    </ul>
  </Container>
</section>

<style>
  .logo-tile { transition-property: transform, border-color; }
  .logo-tile:hover { transform: translateY(-2px); }
  @media (prefers-reduced-motion: reduce) {
    .logo-tile:hover { transform: none; }
  }
</style>
