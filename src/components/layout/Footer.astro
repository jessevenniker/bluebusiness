---
import nl from '../../i18n/nl.json';
import { routeMap } from '../../i18n/routes';
import Container from '../shared/Container.astro';
import Icons from '../shared/Icons.astro';

const t = nl.footer;
const r = routeMap.nl;
const cases = nl.home.cases.items;
const services = nl.home.services.items;
---

<footer class="mt-24 border-t border-[var(--color-border)] pt-16 pb-8">
  <Container>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10">
      <!-- Col 1: brand -->
      <div class="col-span-2 md:col-span-1">
        <a href={r.home} class="flex items-center gap-2.5 mb-4">
          <span class="block w-[14px] h-[14px] rounded-[3px] bg-[var(--color-accent)]"></span>
          <span class="text-[15px] font-medium">Blue Business</span>
        </a>
        <p class="text-body text-fg-dim mb-5 max-w-[26ch]">{t.tagline}</p>
        <div class="flex items-center gap-4">
          <a href="https://www.linkedin.com/company/bluebusiness-nl" aria-label="LinkedIn" class="text-fg-dim hover:text-accent transition-colors">
            <Icons name="linkedin" size={16} />
          </a>
          <a href="https://github.com/bluebusiness" aria-label="GitHub" class="text-fg-dim hover:text-accent transition-colors">
            <Icons name="github" size={16} />
          </a>
          <a href={`mailto:${t.email}`} aria-label="Email" class="text-fg-dim hover:text-accent transition-colors">
            <Icons name="mail" size={16} />
          </a>
        </div>
      </div>

      <!-- Col 2: services -->
      <div>
        <h3 class="text-[13px] font-medium uppercase tracking-[0.06em] text-fg-faint mb-4">{t.columns.services}</h3>
        <ul class="space-y-2.5">
          {services.map((s) => (
            <li>
              <a href={`${r.services}#${s.id}`} class="text-body text-fg-dim hover:text-fg transition-colors">{s.title}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3: cases -->
      <div>
        <h3 class="text-[13px] font-medium uppercase tracking-[0.06em] text-fg-faint mb-4">{t.columns.cases}</h3>
        <ul class="space-y-2.5">
          {cases.map((c) => {
            const title = c.title.replace(/^\[TBD\]\s*/, '');
            return (
              <li>
                <a href={`${r.cases}${c.id}/`} class="text-body text-fg-dim hover:text-fg transition-colors">
                  {c.id === 'bonaire-app' ? 'Bonaire App' : c.id === 'medewerker-app' ? 'Medewerker App' : 'GAST'}
                </a>
              </li>
            );
          })}
          <li>
            <a href={r.cases} class="text-body text-accent hover:text-accent-hi transition-colors">{t.allCases} →</a>
          </li>
        </ul>
      </div>

      <!-- Col 4: contact -->
      <div>
        <h3 class="text-[13px] font-medium uppercase tracking-[0.06em] text-fg-faint mb-4">{t.columns.contact}</h3>
        <address class="not-italic space-y-1.5">
          <p class="text-body text-fg-dim">{t.address.line1}</p>
          <p class="text-body text-fg-dim">{t.address.line2}</p>
          <p class="text-body text-fg-dim">{t.address.line3}</p>
          <p class="font-mono text-[12px] text-fg-faint pt-1">{t.address.kvk}</p>
          <p class="text-body pt-2"><a href={`mailto:${t.email}`} class="text-fg-dim hover:text-fg transition-colors">{t.email}</a></p>
        </address>
      </div>
    </div>

    <div class="mt-14 pt-6 border-t border-[var(--color-accent-line)] flex flex-col md:flex-row items-start md:items-center justify-between gap-4">
      <p class="font-mono text-[12px] text-fg-faint">
        {t.copyright} · {t.address.kvk}
      </p>
      <ul class="flex items-center gap-5 font-mono text-[12px] text-fg-faint">
        <li><a href={r.privacy} class="hover:text-fg-dim transition-colors">{t.legal.privacy}</a></li>
        <li><a href={r.terms} class="hover:text-fg-dim transition-colors">{t.legal.terms}</a></li>
        <li><a href="/llms.txt" class="hover:text-fg-dim transition-colors">{t.legal.llms}</a></li>
      </ul>
    </div>
  </Container>
</footer>
