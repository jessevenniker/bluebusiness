---
import { getContent } from '../../i18n/content';

interface Props {
  locale?: 'nl' | 'en';
  includeFaq?: boolean;
}
const { locale = 'nl', includeFaq = false } = Astro.props;

const baseUrl = Astro.site ? Astro.site.origin : 'https://bluebusiness.nl';
const content = getContent(locale);

const description =
  locale === 'en'
    ? 'Blue Business is a Dutch app development studio founded in 2021, specializing in native iOS and Android apps for SMEs, tourism operators, and Caribbean governments.'
    : 'Blue Business is een Nederlandse app development studio opgericht in 2021, gespecialiseerd in native iOS en Android apps voor MKB, toerisme en Caribbean overheid.';

const graph: Record<string, unknown>[] = [
  {
    '@type': 'Organization',
    '@id': `${baseUrl}/#organization`,
    name: 'Blue Business',
    legalName: 'Blue Innovation B.V.',
    url: `${baseUrl}/`,
    logo: {
      '@type': 'ImageObject',
      url: `${baseUrl}/logo-512.png`,
      width: 512,
      height: 512,
    },
    foundingDate: '2021',
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'Rietsingel 46',
      postalCode: '2136 LB',
      addressLocality: 'Zwaanshoek',
      addressCountry: 'NL',
    },
    areaServed: ['NL', 'CW', 'AW', 'BQ'],
    sameAs: [
      'https://www.linkedin.com/company/bluebusiness-nl',
      'https://github.com/jessevenniker/bluebusiness',
    ],
    email: 'info@bluebusiness.nl',
    identifier: { '@type': 'PropertyValue', propertyID: 'KvK', value: '80387578' },
    description,
  },
  {
    '@type': 'WebSite',
    '@id': `${baseUrl}/#website`,
    url: `${baseUrl}/`,
    name: 'Blue Business',
    publisher: { '@id': `${baseUrl}/#organization` },
    inLanguage: ['nl-NL', 'en'],
  },
];

if (includeFaq) {
  graph.push({
    '@type': 'FAQPage',
    mainEntity: content.home.faq.items.map((item) => ({
      '@type': 'Question',
      name: item.q,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.a,
      },
    })),
  });
}

const schema = {
  '@context': 'https://schema.org',
  '@graph': graph,
};
---

<script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
