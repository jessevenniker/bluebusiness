---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary';
  class?: string;
}
const { href, variant = 'primary', class: className = '' } = Astro.props;

const base =
  'group relative inline-flex items-center gap-2 px-5 py-3 rounded-[10px] text-[15px] font-medium transition-colors duration-200';
const styles =
  variant === 'primary'
    ? 'bg-[var(--color-accent)] text-white hover:bg-[var(--color-accent-hi)]'
    : 'bg-transparent text-fg border border-[var(--color-border-strong)] hover:border-[var(--color-accent)]';
---

<a href={href} class={`${base} ${styles} ${className}`}>
  <slot />
  <svg
    width="14"
    height="14"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.8"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="transition-transform duration-200 group-hover:translate-x-[2px]"
    aria-hidden="true"
  >
    <line x1="5" y1="12" x2="19" y2="12" />
    <polyline points="12 5 19 12 12 19" />
  </svg>
</a>
