---
interface Props {
  name: string;
  size?: number;
  class?: string;
}
const { name, size = 24, class: className = '' } = Astro.props;

const common = `width=${size} height=${size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"`;
---

{name === 'ios-native' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true">
    <rect x="6" y="2.5" width="12" height="19" rx="3" />
    <line x1="10.5" y1="19" x2="13.5" y2="19" />
    <line x1="6" y1="5.5" x2="18" y2="5.5" />
  </svg>
)}
{name === 'web-layer' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true">
    <rect x="3" y="4" width="18" height="10" rx="1.5" />
    <path d="M5.5 17 L18.5 17" />
    <path d="M7 20 L17 20" />
  </svg>
)}
{name === 'design-compass' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true">
    <circle cx="12" cy="12" r="8.5" />
    <line x1="12" y1="3.5" x2="12" y2="20.5" />
    <line x1="3.5" y1="12" x2="20.5" y2="12" />
    <circle cx="12" cy="12" r="1.5" />
  </svg>
)}
{name === 'maintain-loop' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true">
    <path d="M3.5 12 A8.5 8.5 0 0 1 20.5 12" />
    <polyline points="16.5 8 20.5 12 16.5 16" />
    <path d="M20.5 12 A8.5 8.5 0 0 1 3.5 12" />
    <polyline points="7.5 16 3.5 12 7.5 8" />
  </svg>
)}
{name === 'arrow-right' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true">
    <line x1="4" y1="12" x2="20" y2="12" />
    <polyline points="13 5 20 12 13 19" />
  </svg>
)}
{name === 'external-link' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true">
    <path d="M14 4 H20 V10" />
    <line x1="20" y1="4" x2="11" y2="13" />
    <path d="M19 14 V19 A1 1 0 0 1 18 20 H5 A1 1 0 0 1 4 19 V6 A1 1 0 0 1 5 5 H10" />
  </svg>
)}
{name === 'chevron-down' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true">
    <polyline points="6 9 12 15 18 9" />
  </svg>
)}
{name === 'close' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true">
    <line x1="6" y1="6" x2="18" y2="18" />
