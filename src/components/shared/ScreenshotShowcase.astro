---
/**
 * ScreenshotShowcase — uniform phone-frame grid for app screenshots.
 *
 * Renders each screenshot inside a calm phone-frame mock (rounded bezel,
 * faux notch, subtle drop shadow) on a soft brand-color glow. Phones share
 * one column count regardless of how many screenshots a case has, so the
 * layout reads the same on every case page — no awkward "3 hero + 1 lonely"
 * splits when a case only ships 4 screens.
 *
 * Usage:
 *   <ScreenshotShowcase
 *     screenshots={[{ src, alt }, ...]}
 *     accentColor="#3B82F6"
 *   />
 */

interface Screenshot { src: string; alt: string; }

interface Props {
  screenshots: Screenshot[];
  accentColor: string;
}

const { screenshots, accentColor } = Astro.props;

// Decide column count from screenshot count so phones don't blow up to giant
// sizes on a 4-shot case. 3 cols for ≤6, 4 cols for 7+, 5 cols for 9+.
const cols = screenshots.length >= 9 ? 5 : screenshots.length >= 7 ? 4 : 3;
---

<div class="ssx" style={`--accent: ${accentColor}; --cols: ${cols};`}>
  <div class="ssx-glow" aria-hidden="true"></div>

  <ul class="ssx-grid" role="list">
    {screenshots.map((s, i) => (
      <li class="ssx-phone" style={`--tilt: ${i % 2 === 0 ? -2 : 2}deg;`}>
        <div class="ssx-frame">
          <span class="ssx-notch" aria-hidden="true"></span>
          <img src={s.src} alt={s.alt} loading="lazy" decoding="async" />
        </div>
      </li>
    ))}
  </ul>
</div>

<style>
  .ssx {
    position: relative;
    padding: 40px 16px 16px;
    isolation: isolate;
  }

  .ssx-glow {
    position: absolute;
    inset: -5% 0 -5% 0;
    z-index: -1;
    background: radial-gradient(60% 50% at 50% 40%, color-mix(in srgb, var(--accent) 22%, transparent) 0%, transparent 70%);
    filter: blur(50px);
    opacity: 0.7;
    pointer-events: none;
  }

  .ssx-grid {
    display: grid;
    grid-template-columns: repeat(var(--cols, 4), minmax(0, 1fr));
    gap: 20px;
    max-width: 1080px;
    margin: 0 auto;
    align-items: start;
    justify-items: center;
  }

  .ssx-phone {
    list-style: none;
    width: 100%;
    max-width: 200px;
    transform: rotate(var(--tilt, 0deg)) translateY(0);
    transition: transform 280ms var(--ease, cubic-bezier(0.16, 1, 0.3, 1));
    will-change: transform;
  }

  .ssx-phone:hover {
    transform: rotate(0deg) translateY(-6px) scale(1.02);
    z-index: 1;
  }

  .ssx-frame {
    position: relative;
    border-radius: 28px;
    padding: 5px;
    background: linear-gradient(160deg, #1d1d1f 0%, #08080a 100%);
    box-shadow:
      0 18px 36px -10px rgba(0, 0, 0, 0.5),
      0 8px 16px -8px rgba(0, 0, 0, 0.4),
      0 0 0 0.5px rgba(255, 255, 255, 0.12);
    overflow: hidden;
  }

  .ssx-frame img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 23px;
    background: var(--color-bg-elevated, #0E1D3A);
  }

  .ssx-notch {
    position: absolute;
    top: 11px;
    left: 50%;
    transform: translateX(-50%);
    width: 30%;
    max-width: 70px;
    height: 14px;
    background: #08080a;
    border-radius: 0 0 12px 12px;
    z-index: 2;
    pointer-events: none;
  }

  /* Tablet */
  @media (max-width: 1024px) {
    .ssx-grid {
      grid-template-columns: repeat(min(var(--cols), 3), minmax(0, 1fr));
      gap: 16px;
    }
    .ssx-phone { max-width: 180px; }
  }

  /* Small tablet */
  @media (max-width: 720px) {
    .ssx-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
    }
    .ssx-phone { max-width: 170px; }
  }

  /* Mobile */
  @media (max-width: 480px) {
    .ssx { padding: 24px 8px 8px; }
    .ssx-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; }
    .ssx-phone { transform: none !important; max-width: 160px; }
    .ssx-phone:hover { transform: translateY(-3px) !important; }
    .ssx-frame { border-radius: 22px; padding: 4px; }
    .ssx-frame img { border-radius: 18px; }
    .ssx-notch { height: 10px; max-width: 50px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .ssx-phone, .ssx-phone:hover { transform: none !important; transition: none; }
  }
</style>
