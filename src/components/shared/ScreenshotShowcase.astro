---
/**
 * ScreenshotShowcase — premium app-screenshot grid.
 *
 * Renders each screenshot inside a phone-frame mock (rounded bezel + drop
 * shadow + faux notch) on a brand-color radial-gradient backdrop. The first
 * three frames sit on a hero row with subtle staggered tilts; any extras
 * follow in a calm secondary grid that doesn't compete for attention.
 *
 * Usage:
 *   <ScreenshotShowcase
 *     screenshots={[{ src, alt, caption? }, ...]}
 *     accentColor="#3B82F6"
 *   />
 */

interface Screenshot {
  src: string;
  alt: string;
  caption?: string;
}

interface Props {
  screenshots: Screenshot[];
  accentColor: string;
}

const { screenshots, accentColor } = Astro.props;

const heroSet = screenshots.slice(0, 3);
const restSet = screenshots.slice(3);

// Tilts in the hero row. Center is upright, sides lean toward the center.
const heroTilts = [-5, 0, 5];
---

<div class="ssx" style={`--accent: ${accentColor};`}>
  <div class="ssx-glow" aria-hidden="true"></div>

  <ul class="ssx-hero" role="list">
    {heroSet.map((s, i) => (
      <li class="ssx-phone" style={`--tilt: ${heroTilts[i] ?? 0}deg; --delay: ${i * 80}ms;`}>
        <div class="ssx-frame">
          <span class="ssx-notch" aria-hidden="true"></span>
          <img src={s.src} alt={s.alt} loading="lazy" decoding="async" />
        </div>
        {s.caption && <p class="ssx-caption">{s.caption}</p>}
      </li>
    ))}
  </ul>

  {restSet.length > 0 && (
    <ul class="ssx-rest" role="list">
      {restSet.map((s, i) => (
        <li class="ssx-phone ssx-phone--small" style={`--tilt: ${i % 2 === 0 ? -3 : 3}deg; --delay: ${(i + 3) * 60}ms;`}>
          <div class="ssx-frame">
            <span class="ssx-notch" aria-hidden="true"></span>
            <img src={s.src} alt={s.alt} loading="lazy" decoding="async" />
          </div>
          {s.caption && <p class="ssx-caption">{s.caption}</p>}
        </li>
      ))}
    </ul>
  )}
</div>

<style>
  .ssx {
    position: relative;
    padding: 60px 16px 40px;
    isolation: isolate;
  }

  .ssx-glow {
    position: absolute;
    inset: -10% 0 -10% 0;
    z-index: -1;
    background:
      radial-gradient(60% 50% at 50% 40%, color-mix(in srgb, var(--accent) 38%, transparent) 0%, transparent 70%),
      radial-gradient(40% 35% at 20% 80%, color-mix(in srgb, var(--accent) 18%, transparent) 0%, transparent 70%),
      radial-gradient(35% 30% at 85% 70%, color-mix(in srgb, var(--accent) 18%, transparent) 0%, transparent 70%);
    filter: blur(40px);
    opacity: 0.55;
    pointer-events: none;
  }

  .ssx-hero {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
    max-width: 920px;
    margin: 0 auto;
    align-items: center;
  }

  .ssx-rest {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 16px;
    max-width: 1100px;
    margin: 60px auto 0;
  }

  .ssx-phone {
    list-style: none;
    transform: rotate(var(--tilt, 0deg)) translateY(0);
    transition: transform 360ms var(--ease, cubic-bezier(0.16, 1, 0.3, 1));
    will-change: transform;
  }

  .ssx-phone:hover {
    transform: rotate(0deg) translateY(-10px) scale(1.03);
    z-index: 1;
  }

  .ssx-frame {
    position: relative;
    border-radius: 32px;
    padding: 6px;
    background: linear-gradient(160deg, #1d1d1f 0%, #08080a 100%);
    box-shadow:
      0 30px 60px -10px rgba(0, 0, 0, 0.55),
      0 12px 24px -8px rgba(0, 0, 0, 0.45),
      0 0 0 1px rgba(255, 255, 255, 0.06) inset,
      0 0 0 0.5px rgba(255, 255, 255, 0.12);
    overflow: hidden;
  }

  .ssx-frame img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 26px;
    background: var(--color-bg-elevated, #0E1D3A);
  }

  .ssx-notch {
    position: absolute;
    top: 12px;
    left: 50%;
    transform: translateX(-50%);
    width: 32%;
    max-width: 92px;
    height: 18px;
    background: #08080a;
    border-radius: 0 0 14px 14px;
    z-index: 2;
    pointer-events: none;
  }

  .ssx-phone--small .ssx-frame { border-radius: 26px; padding: 5px; }
  .ssx-phone--small .ssx-frame img { border-radius: 22px; }
  .ssx-phone--small .ssx-notch { height: 14px; max-width: 74px; }

  .ssx-caption {
    margin-top: 14px;
    font-size: 13px;
    color: var(--color-fg-dim);
    text-align: center;
    line-height: 1.5;
    transform: rotate(calc(var(--tilt, 0deg) * -1)); /* keep caption upright */
  }

  /* Tablet */
  @media (max-width: 900px) {
    .ssx-hero {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
    }
    .ssx-frame { border-radius: 24px; padding: 4px; }
    .ssx-frame img { border-radius: 20px; }
    .ssx-notch { height: 12px; max-width: 60px; }
  }

  /* Mobile — drop tilts, give each phone breathing room */
  @media (max-width: 600px) {
    .ssx { padding: 40px 8px 24px; }
    .ssx-hero {
      grid-template-columns: 1fr;
      gap: 24px;
      max-width: 320px;
    }
    .ssx-rest {
      grid-template-columns: repeat(2, 1fr);
      gap: 14px;
      margin-top: 32px;
    }
    .ssx-phone { transform: none !important; }
    .ssx-phone:hover { transform: translateY(-6px) !important; }
    .ssx-caption { transform: none !important; }
  }

  @media (prefers-reduced-motion: reduce) {
    .ssx-phone, .ssx-phone:hover { transform: none !important; transition: none; }
    .ssx-caption { transform: none !important; }
  }
</style>
