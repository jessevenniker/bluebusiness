---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/shared/Container.astro';
import MonoEyebrow from '../../../components/shared/MonoEyebrow.astro';
import ArrowButton from '../../../components/shared/ArrowButton.astro';
import ScreenshotShowcase from '../../../components/shared/ScreenshotShowcase.astro';

const baseUrl = Astro.site ? Astro.site.origin : 'https://bluebusiness.nl';
const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'SoftwareApplication',
      '@id': `${baseUrl}/en/cases/bonaire-app/#app`,
      name: 'Visit Bonaire',
      applicationCategory: 'TravelApplication',
      operatingSystem: 'iOS, Android',
      description: 'Visit Bonaire is the all-in-one travel app for visitors of Bonaire. Offline navigation via Mapbox, all highlights, tailored routes and cruise tours.',
      url: `${baseUrl}/en/cases/bonaire-app/`,
      datePublished: '2025-04-29',
      inLanguage: ['nl', 'en'],
      publisher: { '@id': `${baseUrl}/#organization` },
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: '5.0',
        ratingCount: '4',
        bestRating: '5',
        worstRating: '1',
      },
      review: {
        '@type': 'Review',
        reviewBody: 'Super handige app, vooral de offline kaart functie! Internet is hier zo traag. Alle info voor op t eiland.',
        reviewRating: { '@type': 'Rating', ratingValue: '5', bestRating: '5' },
        author: { '@type': 'Person', name: 'App Store user' },
        inLanguage: 'nl',
      },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: `${baseUrl}/en/` },
        { '@type': 'ListItem', position: 2, name: 'Work', item: `${baseUrl}/en/cases/` },
        { '@type': 'ListItem', position: 3, name: 'Visit Bonaire', item: `${baseUrl}/en/cases/bonaire-app/` },
      ],
    },
  ],
};

const features = [
  'Every point of interest on Bonaire',
  'Offline navigation via Mapbox',
  'Tailored routes including turn-by-turn',
  'Cruise tours for day visitors',
  'Photos, descriptions and local tips',
  'Realtime content via Firebase — no app update needed',
];

const screenshots = [
  { src: '/clients/VB-1.webp', alt: 'Visit Bonaire — home screen' },
  { src: '/clients/VB-2.webp', alt: 'Visit Bonaire — map with points of interest' },
  { src: '/clients/VB-3.webp', alt: 'Visit Bonaire — location detail page' },
  { src: '/clients/VB-4.webp', alt: 'Visit Bonaire — tour overview' },
  { src: '/clients/VB-5.webp', alt: 'Visit Bonaire — dive and snorkel sites' },
  { src: '/clients/VB-6.webp', alt: 'Visit Bonaire — restaurants and activities' },
  { src: '/clients/VB-7.webp', alt: 'Visit Bonaire — personalised route' },
  { src: '/clients/VB-8.webp', alt: 'Visit Bonaire — favourites' },
  { src: '/clients/VB-9.webp', alt: 'Visit Bonaire — settings and languages' },
];
---

<BaseLayout
  title="Visit Bonaire — all-in-one travel app for Bonaire | Blue Business"
  description="Visit Bonaire is the all-in-one travel app for visitors of Bonaire — built by Blue Business. Offline navigation via Mapbox, realtime content via Firebase. 5.0★ on the Dutch App Store."
  canonicalPath="/en/cases/bonaire-app/"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />

  <section class="pt-[140px] md:pt-[180px] pb-16">
    <Container>
      <nav aria-label="Breadcrumb" class="mb-10 font-mono text-[12px] text-fg-faint">
        <ol class="flex flex-wrap items-center gap-2">
          <li><a href="/en/" class="hover:text-accent-hi">Home</a></li>
          <li>/</li>
          <li><a href="/en/cases/" class="hover:text-accent-hi">Work</a></li>
          <li>/</li>
          <li class="text-fg-dim">Visit Bonaire</li>
        </ol>
      </nav>

      <MonoEyebrow text="// tourism — Caribbean" tone="accent-hi" class="mb-6 block" />
      <h1 class="text-h1 font-medium max-w-[20ch]" style="letter-spacing: var(--tracking-tight); line-height: 1.02;">
        <span class="block text-fg">Visit Bonaire —</span>
        <span class="block text-accent">you explore, we guide you.</span>
      </h1>
      <p class="text-lead text-fg-dim mt-8 max-w-[60ch]">
        The all-in-one travel app for visitors of Bonaire. From dive sites to beaches to restaurants to tailored tours — all offline, with realtime content that updates without an app release.
      </p>

      <div class="mt-10 flex flex-wrap gap-3">
        <a href="https://apps.apple.com/nl/app/visit-bonaire/id6736879805" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-4 py-2 rounded-[10px] border border-[var(--color-border-strong)] hover:border-accent-line transition-colors text-[14px] text-fg">
          App Store →
        </a>
        <a href="https://www.visit-bonaire.com/" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-4 py-2 rounded-[10px] border border-[var(--color-border-strong)] hover:border-accent-line transition-colors text-[14px] text-fg">
          visit-bonaire.com →
        </a>
      </div>
    </Container>
  </section>

  <section class="py-12 md:py-16 border-t border-[var(--color-accent-line)]">
    <Container>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
        {[
          { k: 'App Store NL', v: '5.0★ · 4 reviews' },
          { k: 'Google Play', v: '1K+ downloads' },
          { k: 'Live since', v: '29 April 2025' },
          { k: 'Platforms', v: 'iOS · Android · iPad · Mac' },
        ].map((s) => (
          <div>
            <p class="font-mono text-[11px] text-fg-faint uppercase tracking-[0.04em] mb-2">{s.k}</p>
            <p class="text-[16px] text-fg">{s.v}</p>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <section class="py-16 md:py-20">
    <Container size="narrow">
      <figure class="p-8 md:p-10 rounded-[14px] bg-[var(--color-bg-elevated)] border border-[var(--color-accent-line)] relative" lang="nl">
        <span aria-hidden="true" class="absolute top-4 left-6 font-mono text-[44px] leading-none text-accent/40">"</span>
        <blockquote class="text-[18px] md:text-[20px] text-fg pl-6" style="line-height: 1.55;">
          <p>Super handige app, vooral de offline kaart functie! Internet is hier zo traag. Alle info voor op t eiland.</p>
        </blockquote>
        <p class="text-[14px] text-fg-dim mt-4 pl-6 italic" lang="en" style="line-height: 1.6;">
          "Really handy app, especially the offline map. Internet is so slow here. All the info you need on the island."
        </p>
        <figcaption class="mt-6 pl-6 flex items-baseline gap-3 flex-wrap">
          <span class="text-[15px] font-medium text-fg">Dutch App Store review</span>
          <span class="font-mono text-[12px] text-fg-faint uppercase tracking-[0.04em]">5 stars</span>
        </figcaption>
      </figure>
    </Container>
  </section>

  <section class="py-20 md:py-24 border-t border-[var(--color-accent-line)]">
    <Container>
      <MonoEyebrow text="// Screenshots" tone="accent-hi" class="mb-5 block" />
      <h2 class="text-h2 font-medium mb-10" style="letter-spacing: var(--tracking-tight); line-height: 1.08;">
        <span class="block text-fg">One island,</span>
        <span class="block text-accent">eleven screens away.</span>
      </h2>
      <ScreenshotShowcase screenshots={screenshots} accentColor="#3B82F6" />
    </Container>
  </section>

  <section class="py-20 md:py-24 border-t border-[var(--color-accent-line)]">
    <Container size="narrow">
      <MonoEyebrow text="// Features" tone="accent-hi" class="mb-5 block" />
      <h2 class="text-h2 font-medium mb-10" style="letter-spacing: var(--tracking-tight); line-height: 1.08;">
        <span class="block text-fg">Everything for</span>
        <span class="block text-accent">one island.</span>
      </h2>
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-3" role="list">
        {features.map((f) => (
          <li class="flex items-start gap-3 p-4 rounded-[10px] bg-[var(--color-bg-elevated)] border border-[var(--color-border)]">
            <span class="w-[6px] h-[6px] mt-[9px] rounded-full bg-[var(--color-accent)] flex-shrink-0"></span>
            <span class="text-[15px] text-fg">{f}</span>
          </li>
        ))}
      </ul>
    </Container>
  </section>

  <section class="py-20 md:py-24 border-t border-[var(--color-accent-line)]">
    <Container size="narrow">
      <MonoEyebrow text="// Tech stack" tone="accent-hi" class="mb-5 block" />
      <h2 class="text-h2 font-medium mb-10" style="letter-spacing: var(--tracking-tight); line-height: 1.08;">
        <span class="block text-fg">Built for</span>
        <span class="block text-accent">working offline.</span>
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="p-6 rounded-[14px] bg-[var(--color-bg-elevated)] border border-[var(--color-border)]">
          <span class="font-mono text-[12px] text-accent-hi uppercase tracking-[0.04em]">Mapbox</span>
          <h3 class="text-[18px] font-medium text-fg mt-2 mb-2">Offline maps</h3>
          <p class="text-[14px] text-fg-dim" style="line-height: 1.6;">Tourists have no data on the island. Mapbox integration means the entire map of Bonaire — including POIs, dive sites and routes — is available locally.</p>
        </div>
        <div class="p-6 rounded-[14px] bg-[var(--color-bg-elevated)] border border-[var(--color-border)]">
          <span class="font-mono text-[12px] text-accent-hi uppercase tracking-[0.04em]">Firebase</span>
          <h3 class="text-[18px] font-medium text-fg mt-2 mb-2">Realtime content</h3>
          <p class="text-[14px] text-fg-dim" style="line-height: 1.6;">Opening hours, new locations and promo content can be updated without an app release. Realtime data with structured storage for scale.</p>
        </div>
      </div>
    </Container>
  </section>

  <section class="py-32 md:py-40 border-t border-[var(--color-accent-line)] relative overflow-hidden">
    <div aria-hidden="true" class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse at center, rgba(59, 130, 246, 0.08) 0%, transparent 60%);"></div>
    <Container size="narrow">
      <div class="text-center relative">
        <MonoEyebrow text="// Your idea, our next case?" tone="dim" class="mb-6 block" />
        <h2 class="text-h2 font-medium mb-6" style="letter-spacing: var(--tracking-tight); line-height: 1.08;">
          <span class="block text-fg">Tourism apps</span>
          <span class="block text-accent">that work offline.</span>
        </h2>
        <p class="text-lead text-fg-dim mb-10 max-w-[50ch] mx-auto">Island guide, regional app, museum tour — tell us what you have in mind and we'll share what we learned from Visit Bonaire and Bonaire Cruisers.</p>
        <div class="flex justify-center">
          <ArrowButton href="/en/contact/" variant="primary">Schedule a call</ArrowButton>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
