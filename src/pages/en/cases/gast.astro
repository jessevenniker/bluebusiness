---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/shared/Container.astro';
import MonoEyebrow from '../../../components/shared/MonoEyebrow.astro';
import ArrowButton from '../../../components/shared/ArrowButton.astro';
import ScreenshotShowcase from '../../../components/shared/ScreenshotShowcase.astro';
import RelatedCases from '../../../components/shared/RelatedCases.astro';

const baseUrl = Astro.site ? Astro.site.origin : 'https://bluebusiness.nl';
const schema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'GAST',
  operatingSystem: 'iOS, Android',
  applicationCategory: 'BusinessApplication',
  url: `${baseUrl}/en/cases/gast/`,
  inLanguage: 'nl',
  publisher: { '@id': `${baseUrl}/#organization` },
  about: 'Employee app for holiday-park staff, built on the Medewerker.app platform. Live at Hof van Saksen and Roompot.',
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.5',
    ratingCount: '4',
    bestRating: '5',
    worstRating: '1',
  },
};

const clients = [
  { name: 'Hof van Saksen', sector: 'Holiday parks', logo: '/clients/hof-van-saksen.png' },
  { name: 'Roompot', sector: 'Holiday parks', logo: '/clients/roompot.png' },
];

const screenshots = [
  { src: '/clients/GT-1.webp', alt: 'GAST — staff home screen' },
  { src: '/clients/GT-2.webp', alt: 'GAST — news and updates' },
  { src: '/clients/GT-3.webp', alt: 'GAST — documents and information' },
  { src: '/clients/GT-4.webp', alt: 'GAST — internal communication' },
];
---

<BaseLayout
  title="GAST — employee app for hospitality | Blue Business"
  description="GAST is the employee app for holiday-park staff, built on the Medewerker.app platform. Live at Hof van Saksen and Roompot. Live since 2020."
  canonicalPath="/en/cases/gast/"
  ogImage="/og/cases/gast.png"
  breadcrumbs={[{ name: 'Home', path: '/en/' }, { name: 'Work', path: '/en/cases/' }, { name: 'GAST', path: '/en/cases/gast/' }]}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />

  <section class="pt-[140px] md:pt-[180px] pb-16">
    <Container>
      <nav aria-label="Breadcrumb" class="mb-10 font-mono text-[12px] text-fg-faint">
        <ol class="flex flex-wrap items-center gap-2">
          <li><a href="/en/" class="hover:text-accent-hi">Home</a></li>
          <li>/</li>
          <li><a href="/en/cases/" class="hover:text-accent-hi">Work</a></li>
          <li>/</li>
          <li class="text-fg-dim">GAST</li>
        </ol>
      </nav>

      <MonoEyebrow text="// hospitality — internal comms" tone="accent-hi" class="mb-6 block" />
      <h1 class="text-h1 font-medium max-w-[20ch]" style="letter-spacing: var(--tracking-tight); line-height: 1.02;">
        <span class="block text-fg">GAST — employee app</span>
        <span class="block text-accent">for hospitality.</span>
      </h1>
      <p class="text-lead text-fg-dim mt-8 max-w-[60ch]">
        Native iOS and Android app for the staff of holiday parks. GAST runs on the same platform as Medewerker.app, but specifically positioned for hospitality teams: front-desk staff, animation teams, technical service and housekeeping get one place for news, documents, schedules and internal communication.
      </p>
      <p class="font-mono text-[12px] text-fg-faint uppercase tracking-[0.04em] mt-6">
        Built by Blue Business for IDC Tech B.V. · live since 2020, fully redesigned in August 2025
      </p>

      <div class="mt-10 flex flex-wrap gap-3">
        <a href="https://apps.apple.com/nl/app/gast/id1468467772" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-4 py-2 rounded-[10px] border border-[var(--color-border-strong)] hover:border-accent-line transition-colors text-[14px] text-fg">
          App Store →
        </a>
      </div>
    </Container>
  </section>

  <section class="py-12 md:py-16 border-t border-[var(--color-accent-line)]">
    <Container>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
        {[
          { k: 'App Store NL', v: '4.5★ · 4 reviews' },
          { k: 'Google Play', v: '4.2★ · 6 reviews · 500+' },
          { k: 'Live since', v: '2020 · redesign Aug 2025' },
          { k: 'Platforms', v: 'iOS · Android' },
        ].map((s) => (
          <div>
            <p class="font-mono text-[11px] text-fg-faint uppercase tracking-[0.04em] mb-2">{s.k}</p>
            <p class="text-[16px] text-fg">{s.v}</p>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <section class="py-16 md:py-20 border-t border-[var(--color-accent-line)]">
    <Container>
      <h2 class="font-mono text-[12px] text-accent-hi uppercase tracking-[0.04em] mb-8">Live customers</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {clients.map((c) => (
          <div class="p-6 rounded-[14px] bg-white border border-[var(--color-border)] flex items-center justify-center min-h-[140px]">
            <img src={c.logo} alt={`${c.name}, ${c.sector}`} class="max-h-[72px] max-w-full object-contain" loading="lazy" />
          </div>
        ))}
      </div>
      <ul class="grid grid-cols-1 sm:grid-cols-2 gap-6 mt-3" aria-hidden="true">
        {clients.map((c) => (
          <li class="text-center">
            <p class="font-mono text-[11px] text-fg-faint uppercase tracking-[0.04em]">{c.sector}</p>
          </li>
        ))}
      </ul>
    </Container>
  </section>

  <section class="py-20 md:py-24">
    <Container size="narrow">
      <h2 class="text-h3 font-medium text-fg mb-4" style="letter-spacing: var(--tracking-snug);">What we built</h2>
      <p class="text-[16px] text-fg-dim mb-6" style="line-height: 1.7;">
        A native iOS and Android app that connects holiday-park staff directly with management, HR and colleagues. Announcements, daily schedules, house rules and operational updates arrive as push notifications. Documents like work instructions, safety protocols and handbooks are one tap away, in the park's own brand.
      </p>
      <p class="text-[16px] text-fg-dim" style="line-height: 1.7;">
        Because GAST and Medewerker.app share one codebase, both products benefit from the same release cycles, the same stability and the same admin tooling. For parks like Hof van Saksen and Roompot that means: one supplier, two branding variants on one platform, and ongoing maintenance covering the actual mobile workday of everyone on site.
      </p>

      <h2 class="text-h3 font-medium text-fg mt-12 mb-4" style="letter-spacing: var(--tracking-snug);">Key features</h2>
      <ul class="space-y-3 text-[15px] text-fg-dim" role="list">
        <li class="flex gap-3"><span class="text-accent mt-[6px]">→</span> Push notifications for operational updates and announcements</li>
        <li class="flex gap-3"><span class="text-accent mt-[6px]">→</span> News feed for team and park updates</li>
        <li class="flex gap-3"><span class="text-accent mt-[6px]">→</span> Document library for work instructions, protocols, handbooks</li>
        <li class="flex gap-3"><span class="text-accent mt-[6px]">→</span> Onboarding flows for new seasonal and permanent staff</li>
        <li class="flex gap-3"><span class="text-accent mt-[6px]">→</span> Surveys and polls for two-way communication</li>
        <li class="flex gap-3"><span class="text-accent mt-[6px]">→</span> White-label per park: own logo, colours, content and languages</li>
      </ul>

      <h2 class="text-h3 font-medium text-fg mt-12 mb-4" style="letter-spacing: var(--tracking-snug);">Tech stack</h2>
      <ul class="space-y-3 text-[15px] text-fg-dim" role="list">
        <li class="flex gap-3"><span class="text-accent mt-[6px]">→</span> Native iOS (Swift, SwiftUI) and native Android (Kotlin, Compose)</li>
        <li class="flex gap-3"><span class="text-accent mt-[6px]">→</span> Shared backend with Medewerker.app, multi-tenant and white-labelable</li>
        <li class="flex gap-3"><span class="text-accent mt-[6px]">→</span> Web admin for HR and park management: content, audiences, push campaigns</li>
        <li class="flex gap-3"><span class="text-accent mt-[6px]">→</span> Integration with existing HR and planning systems</li>
      </ul>
    </Container>
  </section>

  <section class="py-20 md:py-24 border-t border-[var(--color-accent-line)]">
    <Container>
      <MonoEyebrow text="// Screenshots" tone="accent-hi" class="mb-5 block" />
      <h2 class="text-h2 font-medium mb-10" style="letter-spacing: var(--tracking-tight); line-height: 1.08;">
        <span class="block text-fg">One app for</span>
        <span class="block text-accent">the entire park team.</span>
      </h2>
      <ScreenshotShowcase screenshots={screenshots} accentColor="#A78BFA" />
    </Container>
  </section>

  <RelatedCases currentId="gast" />

  <section class="py-24 md:py-32 border-t border-[var(--color-accent-line)] relative overflow-hidden">
    <div aria-hidden="true" class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse at center, rgba(59, 130, 246, 0.08) 0%, transparent 60%);"></div>
    <Container size="narrow">
      <div class="text-center relative">
        <MonoEyebrow text="// Building something similar?" tone="dim" class="mb-6 block" />
        <h2 class="text-h2 font-medium mb-6" style="letter-spacing: var(--tracking-tight); line-height: 1.08;">
          <span class="block text-fg">An employee app</span>
          <span class="block text-accent">for your holiday park?</span>
        </h2>
        <p class="text-lead text-fg-dim mb-10 max-w-[50ch] mx-auto">Holiday park, hotel chain or camping group with a large on-site team? GAST is proven technology. We shape it around your teams and your brand.</p>
        <div class="flex justify-center">
          <ArrowButton href="/en/contact/" variant="primary">Schedule a call</ArrowButton>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
