---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/shared/Container.astro';
import MonoEyebrow from '../../../components/shared/MonoEyebrow.astro';
import ArrowButton from '../../../components/shared/ArrowButton.astro';

const baseUrl = Astro.site ? Astro.site.origin : 'https://bluebusiness.nl';
const schema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Medewerker.app',
  operatingSystem: 'iOS, Android',
  applicationCategory: 'BusinessApplication',
  url: `${baseUrl}/en/cases/medewerker-app/`,
  inLanguage: 'nl',
  publisher: { '@id': `${baseUrl}/#organization` },
  about: 'Native iOS and Android app for internal communication, scheduling, learning paths and gamification — live at Hof van Saksen, Roompot and Run2Forty2.',
  review: {
    '@type': 'Review',
    reviewBody: "Medewerker.app heeft de afgelopen twee jaar een belangrijke rol gespeeld in de communicatie met alle collega's in onze organisatie. Zo kunnen we iedereen op hetzelfde moment informeren met het laatste nieuws en successen delen. We gebruiken Medewerker.app als centrale app waarin medewerkers alle informatie kunnen vinden die ze nodig hebben, wegwijs maakt en waar iedereen zelf ideeën kan inbrengen.",
    author: {
      '@type': 'Person',
      name: 'Eric van der Heijden',
      jobTitle: 'General Manager',
      worksFor: { '@type': 'Organization', name: 'Hof van Saksen' },
    },
    inLanguage: 'nl',
  },
};

const clients = [
  { name: 'Hof van Saksen', sector: 'Holiday parks', logo: '/clients/hof-van-saksen.png' },
  { name: 'Roompot', sector: 'Holiday parks', logo: '/clients/roompot.png' },
  { name: 'Run2Forty2', sector: 'Marathon travel & training', logo: '/clients/run2forty2.png' },
];

const screenshots = [
  { src: '/clients/mw-1.webp', alt: 'Medewerker — home screen' },
  { src: '/clients/MW-2.webp', alt: 'Medewerker — news feed' },
  { src: '/clients/MW-3.webp', alt: 'Medewerker — onboarding flow' },
  { src: '/clients/MW-4.webp', alt: 'Medewerker — learning paths and quiz' },
  { src: '/clients/MW-5.webp', alt: 'Medewerker — documents and handbooks' },
];

const platformVariants = [
  { src: '/clients/RT-1.webp', alt: 'Run2Forty2 — home screen on the Medewerker platform' },
  { src: '/clients/RT-2.webp', alt: 'Run2Forty2 — training overview' },
  { src: '/clients/RT-3.webp', alt: 'Run2Forty2 — chat with trainer' },
  { src: '/clients/RT-4.webp', alt: 'Run2Forty2 — kudos and community' },
];
---

<BaseLayout
  title="Medewerker.app — internal communication platform | Blue Business"
  description="Medewerker.app is a native iOS and Android app for internal communication, scheduling, learning paths and gamification. Built by Blue Business, live at Hof van Saksen, Roompot and Run2Forty2."
  canonicalPath="/en/cases/medewerker-app/"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />

  <section class="pt-[140px] md:pt-[180px] pb-16">
    <Container>
      <nav aria-label="Breadcrumb" class="mb-10 font-mono text-[12px] text-fg-faint">
        <ol class="flex flex-wrap items-center gap-2">
          <li><a href="/en/" class="hover:text-accent-hi">Home</a></li>
          <li>/</li>
          <li><a href="/en/cases/" class="hover:text-accent-hi">Work</a></li>
          <li>/</li>
          <li class="text-fg-dim">Medewerker.app</li>
        </ol>
      </nav>

      <MonoEyebrow text="// B2B — employee platform" tone="accent-hi" class="mb-6 block" />
      <h1 class="text-h1 font-medium max-w-[20ch]" style="letter-spacing: var(--tracking-tight); line-height: 1.02;">
        <span class="block text-fg">Medewerker.app —</span>
        <span class="block text-accent">internal comms for teams.</span>
      </h1>
      <p class="text-lead text-fg-dim mt-8 max-w-[60ch]">
        Native iOS and Android app that combines push notifications, news, onboarding, learning paths and gamification in one tool. Replaces scattered WhatsApp groups, intranet portals and email blasts with one platform that staff actually open — because it's faster than the alternative.
      </p>
      <p class="font-mono text-[12px] text-fg-faint uppercase tracking-[0.04em] mt-6">
        Built by Blue Business for IDC Tech B.V. · live on the App Store since June 2022
      </p>

      <div class="mt-10 flex flex-wrap gap-3">
        <a href="https://apps.apple.com/nl/app/medewerker/id1625432010" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-4 py-2 rounded-[10px] border border-[var(--color-border-strong)] hover:border-accent-line transition-colors text-[14px] text-fg">
          App Store →
        </a>
        <a href="https://medewerker.app/" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-4 py-2 rounded-[10px] border border-[var(--color-border-strong)] hover:border-accent-line transition-colors text-[14px] text-fg">
          medewerker.app →
        </a>
      </div>
    </Container>
  </section>

  <section class="py-16 md:py-20 border-t border-[var(--color-accent-line)]">
    <Container>
      <h2 class="font-mono text-[12px] text-accent-hi uppercase tracking-[0.04em] mb-8">Live customers</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        {clients.map((c) => (
          <div class="p-6 rounded-[14px] bg-white border border-[var(--color-border)] flex items-center justify-center min-h-[140px]">
            <img src={c.logo} alt={`${c.name} — ${c.sector}`} class="max-h-[72px] max-w-full object-contain" loading="lazy" />
          </div>
        ))}
      </div>
      <ul class="grid grid-cols-1 sm:grid-cols-3 gap-6 mt-3" aria-hidden="true">
        {clients.map((c) => (
          <li class="text-center">
            <p class="font-mono text-[11px] text-fg-faint uppercase tracking-[0.04em]">{c.sector}</p>
          </li>
        ))}
      </ul>
    </Container>
  </section>

  <section class="py-20 md:py-24">
    <Container size="narrow">
      <h2 class="text-h3 font-medium text-fg mb-4" style="letter-spacing: var(--tracking-snug);">What we built</h2>
      <p class="text-[16px] text-fg-dim mb-6" style="line-height: 1.7;">
        A mobile app that opens a direct line from managers and HR to the people on the floor — without going through email distribution lists or notice boards. Announcements arrive as push notifications, news posts are searchable, and documents like staff handbooks or safety instructions are one tap away.
      </p>
      <p class="text-[16px] text-fg-dim" style="line-height: 1.7;">
        For staff it's a daily place to check the schedule, take part in a quiz, submit an idea via the suggestion box, or welcome a new colleague through an onboarding flow. The platform now runs at holiday parks (Hof van Saksen, Roompot) where it scales across thousands of employees, and at Run2Forty2 for communication with marathon trainees.
      </p>

      <h2 class="text-h3 font-medium text-fg mt-12 mb-4" style="letter-spacing: var(--tracking-snug);">Key features</h2>
      <ul class="space-y-3 text-[15px] text-fg-dim" role="list">
        <li class="flex gap-3"><span class="text-accent mt-[6px]">→</span> Push notifications and news feed for internal announcements</li>
        <li class="flex gap-3"><span class="text-accent mt-[6px]">→</span> Document library for handbooks, policies, instructions</li>
        <li class="flex gap-3"><span class="text-accent mt-[6px]">→</span> Onboarding flows for new staff with checklists and explainers</li>
        <li class="flex gap-3"><span class="text-accent mt-[6px]">→</span> Learning paths and quizzes with gamification, badges and leaderboards</li>
        <li class="flex gap-3"><span class="text-accent mt-[6px]">→</span> Surveys, polls and a suggestion box for two-way communication</li>
        <li class="flex gap-3"><span class="text-accent mt-[6px]">→</span> Web admin for HR and management to control content and audiences</li>
      </ul>

      <figure class="mt-14 p-8 md:p-10 rounded-[14px] bg-[var(--color-bg-elevated)] border border-[var(--color-accent-line)] relative" lang="nl">
        <span aria-hidden="true" class="absolute top-4 left-6 font-mono text-[44px] leading-none text-accent/40">"</span>
        <blockquote class="text-[18px] md:text-[20px] text-fg pl-6" style="line-height: 1.55;">
          <p>Medewerker.app heeft de afgelopen twee jaar een belangrijke rol gespeeld in de communicatie met alle collega's in onze organisatie. Zo kunnen we iedereen op hetzelfde moment informeren met het laatste nieuws en successen delen. We gebruiken Medewerker.app als centrale app waarin medewerkers alle informatie kunnen vinden die ze nodig hebben, wegwijs maakt en waar iedereen zelf ideeën kan inbrengen.</p>
        </blockquote>
        <p class="text-[14px] text-fg-dim mt-4 pl-6 italic" lang="en" style="line-height: 1.6;">
          "Over the past two years, Medewerker.app has played an important role in communication with everyone in our organisation. It lets us inform everyone at the same time, share news and celebrate wins together. We use Medewerker.app as the central place where staff find all the information they need, get pointed in the right direction, and can submit their own ideas."
        </p>
        <figcaption class="mt-6 pl-6 flex items-baseline gap-3 flex-wrap">
          <span class="text-[15px] font-medium text-fg">Eric van der Heijden</span>
          <span class="font-mono text-[12px] text-fg-faint uppercase tracking-[0.04em]">General Manager · Hof van Saksen</span>
        </figcaption>
      </figure>

      <h2 class="text-h3 font-medium text-fg mt-12 mb-4" style="letter-spacing: var(--tracking-snug);">Tech stack</h2>
      <ul class="space-y-3 text-[15px] text-fg-dim" role="list">
        <li class="flex gap-3"><span class="text-accent mt-[6px]">→</span> iOS — Swift, SwiftUI, push notifications via APNs</li>
        <li class="flex gap-3"><span class="text-accent mt-[6px]">→</span> Android — Kotlin, Jetpack Compose, FCM</li>
        <li class="flex gap-3"><span class="text-accent mt-[6px]">→</span> Backend: multi-tenant, white-labelable, web admin in TypeScript</li>
        <li class="flex gap-3"><span class="text-accent mt-[6px]">→</span> Analytics + crash reporting for stable rollout across thousands of devices</li>
      </ul>
    </Container>
  </section>

  <section class="py-20 md:py-24 border-t border-[var(--color-accent-line)]">
    <Container>
      <MonoEyebrow text="// Screenshots" tone="accent-hi" class="mb-5 block" />
      <h2 class="text-h2 font-medium mb-10" style="letter-spacing: var(--tracking-tight); line-height: 1.08;">
        <span class="block text-fg">One app,</span>
        <span class="block text-accent">thousands of staff.</span>
      </h2>
      <ul class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4" role="list">
        {screenshots.map((s) => (
          <li class="rounded-[14px] overflow-hidden border border-[var(--color-border)] bg-[var(--color-bg-elevated)]">
            <img src={s.src} alt={s.alt} class="block w-full h-auto" loading="lazy" decoding="async" />
          </li>
        ))}
      </ul>

      <h3 class="text-h3 font-medium text-fg mt-16 mb-3" style="letter-spacing: var(--tracking-snug);">Same platform, different brand: Run2Forty2</h3>
      <p class="text-[15px] text-fg-dim mb-6 max-w-[60ch]" style="line-height: 1.65;">
        Run2Forty2 is a separate App Store app running on the same platform as Medewerker. Marathon trainees get training schedules, news updates and a kudos feature — same technical foundation, different audience and visual identity.
      </p>
      <ul class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4" role="list">
        {platformVariants.map((s) => (
          <li class="rounded-[14px] overflow-hidden border border-[var(--color-border)] bg-[var(--color-bg-elevated)]">
            <img src={s.src} alt={s.alt} class="block w-full h-auto" loading="lazy" decoding="async" />
          </li>
        ))}
      </ul>
      <p class="font-mono text-[12px] text-fg-faint mt-4">
        Run2Forty2 on the <a href="https://apps.apple.com/nl/app/run2forty2/id6448728310" target="_blank" rel="noopener" class="text-accent hover:text-accent-hi underline underline-offset-2">Dutch App Store</a>
      </p>
    </Container>
  </section>

  <section class="py-24 md:py-32 border-t border-[var(--color-accent-line)] relative overflow-hidden">
    <div aria-hidden="true" class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse at center, rgba(59, 130, 246, 0.08) 0%, transparent 60%);"></div>
    <Container size="narrow">
      <div class="text-center relative">
        <MonoEyebrow text="// Building something similar?" tone="dim" class="mb-6 block" />
        <h2 class="text-h2 font-medium mb-6" style="letter-spacing: var(--tracking-tight); line-height: 1.08;">
          <span class="block text-fg">Employee apps</span>
          <span class="block text-accent">are our daily work.</span>
        </h2>
        <p class="text-lead text-fg-dim mb-10 max-w-[50ch] mx-auto">Tell us what you have in mind and we'll share concrete experience from Hof van Saksen, Roompot or Run2Forty2.</p>
        <div class="flex justify-center">
          <ArrowButton href="/en/contact/" variant="primary">Schedule a call</ArrowButton>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
