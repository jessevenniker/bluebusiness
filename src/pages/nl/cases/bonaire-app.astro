---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/shared/Container.astro';
import MonoEyebrow from '../../../components/shared/MonoEyebrow.astro';
import ArrowButton from '../../../components/shared/ArrowButton.astro';
import ScreenshotShowcase from '../../../components/shared/ScreenshotShowcase.astro';

const baseUrl = Astro.site ? Astro.site.origin : 'https://bluebusiness.nl';
const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'SoftwareApplication',
      '@id': `${baseUrl}/nl/cases/bonaire-app/#app`,
      name: 'Visit Bonaire',
      applicationCategory: 'TravelApplication',
      operatingSystem: 'iOS, Android',
      description: 'Visit Bonaire is de alles-in-één reisapp voor bezoekers van Bonaire. Offline navigatie via Mapbox, alle highlights, op maat gemaakte routes en cruise-tours.',
      url: `${baseUrl}/nl/cases/bonaire-app/`,
      datePublished: '2024-11-11',
      inLanguage: ['nl', 'en'],
      publisher: { '@id': `${baseUrl}/#organization` },
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: '5.0',
        ratingCount: '4',
        bestRating: '5',
        worstRating: '1',
      },
      review: {
        '@type': 'Review',
        reviewBody: 'Super handige app, vooral de offline kaart functie! Internet is hier zo traag. Alle info voor op t eiland.',
        reviewRating: { '@type': 'Rating', ratingValue: '5', bestRating: '5' },
        author: { '@type': 'Person', name: 'App Store-gebruiker' },
        inLanguage: 'nl',
      },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: `${baseUrl}/nl/` },
        { '@type': 'ListItem', position: 2, name: 'Cases', item: `${baseUrl}/nl/cases/` },
        { '@type': 'ListItem', position: 3, name: 'Visit Bonaire', item: `${baseUrl}/nl/cases/bonaire-app/` },
      ],
    },
  ],
};

const features = [
  'Alle points-of-interest van Bonaire',
  'Offline navigatie via Mapbox',
  'Op maat gemaakte routes inclusief turn-by-turn',
  'Cruise-tours voor dagtoeristen',
  'Inspirerende foto\u2019s, beschrijvingen en lokale tips',
  'Realtime content via Firebase — geen app-update nodig',
];

const screenshots = [
  { src: '/clients/VB-1.webp', alt: 'Visit Bonaire — startscherm' },
  { src: '/clients/VB-2.webp', alt: 'Visit Bonaire — kaart met points-of-interest' },
  { src: '/clients/VB-3.webp', alt: 'Visit Bonaire — detailpagina van een locatie' },
  { src: '/clients/VB-4.webp', alt: 'Visit Bonaire — tour-overzicht' },
  { src: '/clients/VB-5.webp', alt: 'Visit Bonaire — duik- en snorkelplekken' },
  { src: '/clients/VB-6.webp', alt: 'Visit Bonaire — restaurants en activiteiten' },
  { src: '/clients/VB-7.webp', alt: 'Visit Bonaire — gepersonaliseerde route' },
  { src: '/clients/VB-8.webp', alt: 'Visit Bonaire — favorieten' },
  { src: '/clients/VB-9.webp', alt: 'Visit Bonaire — instellingen en talen' },
];
---

<BaseLayout
  title="Visit Bonaire — reisapp voor Bonaire | Blue Business"
  description="Visit Bonaire — alles-in-één reisapp voor bezoekers van Bonaire. Offline kaarten (Mapbox) + realtime content (Firebase). 5.0★ App Store NL."
  canonicalPath="/nl/cases/bonaire-app/"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />

  <!-- Hero -->
  <section class="pt-[140px] md:pt-[180px] pb-16">
    <Container>
      <nav aria-label="Breadcrumb" class="mb-10 font-mono text-[12px] text-fg-faint">
        <ol class="flex flex-wrap items-center gap-2">
          <li><a href="/nl/" class="hover:text-accent-hi">Home</a></li>
          <li>/</li>
          <li><a href="/nl/cases/" class="hover:text-accent-hi">Cases</a></li>
          <li>/</li>
          <li class="text-fg-dim">Visit Bonaire</li>
        </ol>
      </nav>

      <MonoEyebrow text="// tourism — Caribbean" tone="accent-hi" class="mb-6 block" />
      <h1 class="text-h1 font-medium max-w-[20ch]" style="letter-spacing: var(--tracking-tight); line-height: 1.02;">
        <span class="block text-fg">Visit Bonaire —</span>
        <span class="block text-accent">you explore, we guide you.</span>
      </h1>
      <p class="text-lead text-fg-dim mt-8 max-w-[60ch]">
        De alles-in-één reisapp voor bezoekers van Bonaire. Van duikspots tot stranden tot restaurants tot op maat gemaakte tours — alles offline, met realtime content die zonder app-update bijgewerkt kan worden.
      </p>

      <div class="mt-10 flex flex-wrap gap-3">
        <a href="https://apps.apple.com/nl/app/visit-bonaire/id6736879805" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-4 py-2 rounded-[10px] border border-[var(--color-border-strong)] hover:border-accent-line transition-colors text-[14px] text-fg">
          App Store →
        </a>
        <a href="https://www.visit-bonaire.com/" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-4 py-2 rounded-[10px] border border-[var(--color-border-strong)] hover:border-accent-line transition-colors text-[14px] text-fg">
          visit-bonaire.com →
        </a>
      </div>
    </Container>
  </section>

  <!-- Stats -->
  <section class="py-12 md:py-16 border-t border-[var(--color-accent-line)]">
    <Container>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
        {[
          { k: 'App Store NL', v: '5.0★ · 4 reviews' },
          { k: 'Google Play', v: '1K+ downloads' },
          { k: 'Live sinds', v: '11 november 2024' },
          { k: 'Platforms', v: 'iOS · iPadOS · Android' },
        ].map((s) => (
          <div>
            <p class="font-mono text-[11px] text-fg-faint uppercase tracking-[0.04em] mb-2">{s.k}</p>
            <p class="text-[16px] text-fg">{s.v}</p>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- Quote -->
  <section class="py-16 md:py-20">
    <Container size="narrow">
      <figure class="p-8 md:p-10 rounded-[14px] bg-[var(--color-bg-elevated)] border border-[var(--color-accent-line)] relative">
        <span aria-hidden="true" class="absolute top-4 left-6 font-mono text-[44px] leading-none text-accent/40">"</span>
        <blockquote class="text-[18px] md:text-[20px] text-fg pl-6" style="line-height: 1.55;">
          <p>Super handige app, vooral de offline kaart functie! Internet is hier zo traag. Alle info voor op t eiland.</p>
        </blockquote>
        <figcaption class="mt-6 pl-6 flex items-baseline gap-3 flex-wrap">
          <span class="text-[15px] font-medium text-fg">Review op de App Store NL</span>
          <span class="font-mono text-[12px] text-fg-faint uppercase tracking-[0.04em]">5 sterren</span>
        </figcaption>
      </figure>
    </Container>
  </section>

  <!-- Screenshots -->
  <section class="py-20 md:py-24 border-t border-[var(--color-accent-line)]">
    <Container>
      <MonoEyebrow text="// Screenshots" tone="accent-hi" class="mb-5 block" />
      <h2 class="text-h2 font-medium mb-10" style="letter-spacing: var(--tracking-tight); line-height: 1.08;">
        <span class="block text-fg">Eén eiland,</span>
        <span class="block text-accent">elf schermen ver.</span>
      </h2>
      <ScreenshotShowcase screenshots={screenshots} accentColor="#3B82F6" />
    </Container>
  </section>

  <!-- Features -->
  <section class="py-20 md:py-24 border-t border-[var(--color-accent-line)]">
    <Container size="narrow">
      <MonoEyebrow text="// Functionaliteiten" tone="accent-hi" class="mb-5 block" />
      <h2 class="text-h2 font-medium mb-10" style="letter-spacing: var(--tracking-tight); line-height: 1.08;">
        <span class="block text-fg">Alles voor</span>
        <span class="block text-accent">één eiland.</span>
      </h2>
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-3" role="list">
        {features.map((f) => (
          <li class="flex items-start gap-3 p-4 rounded-[10px] bg-[var(--color-bg-elevated)] border border-[var(--color-border)]">
            <span class="w-[6px] h-[6px] mt-[9px] rounded-full bg-[var(--color-accent)] flex-shrink-0"></span>
            <span class="text-[15px] text-fg">{f}</span>
          </li>
        ))}
      </ul>
    </Container>
  </section>

  <!-- Tech stack -->
  <section class="py-20 md:py-24 border-t border-[var(--color-accent-line)]">
    <Container size="narrow">
      <MonoEyebrow text="// Tech-stack" tone="accent-hi" class="mb-5 block" />
      <h2 class="text-h2 font-medium mb-10" style="letter-spacing: var(--tracking-tight); line-height: 1.08;">
        <span class="block text-fg">Gebouwd voor</span>
        <span class="block text-accent">offline werken.</span>
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="p-6 rounded-[14px] bg-[var(--color-bg-elevated)] border border-[var(--color-border)]">
          <span class="font-mono text-[12px] text-accent-hi uppercase tracking-[0.04em]">Mapbox</span>
          <h3 class="text-[18px] font-medium text-fg mt-2 mb-2">Offline kaarten</h3>
          <p class="text-[14px] text-fg-dim" style="line-height: 1.6;">Toeristen hebben onderweg geen internet. Mapbox-integratie zorgt dat de hele kaart van Bonaire — inclusief points-of-interest, duikspots en routes — lokaal beschikbaar is.</p>
        </div>
        <div class="p-6 rounded-[14px] bg-[var(--color-bg-elevated)] border border-[var(--color-border)]">
          <span class="font-mono text-[12px] text-accent-hi uppercase tracking-[0.04em]">Firebase</span>
          <h3 class="text-[18px] font-medium text-fg mt-2 mb-2">Realtime content</h3>
          <p class="text-[14px] text-fg-dim" style="line-height: 1.6;">Openingstijden, nieuwe locaties en promo-content kunnen zonder app-update worden aangepast. Realtime data met gestructureerde opslag voor schaalbaarheid.</p>
        </div>
      </div>
    </Container>
  </section>

  <!-- CTA -->
  <section class="py-32 md:py-40 border-t border-[var(--color-accent-line)] relative overflow-hidden">
    <div aria-hidden="true" class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse at center, rgba(59, 130, 246, 0.08) 0%, transparent 60%);"></div>
    <Container size="narrow">
      <div class="text-center relative">
        <MonoEyebrow text="// Jouw idee, onze volgende case?" tone="dim" class="mb-6 block" />
        <h2 class="text-h2 font-medium mb-6" style="letter-spacing: var(--tracking-tight); line-height: 1.08;">
          <span class="block text-fg">Toerisme-apps die</span>
          <span class="block text-accent">offline gewoon werken.</span>
        </h2>
        <p class="text-lead text-fg-dim mb-10 max-w-[50ch] mx-auto">Eiland-gids, regio-app, museum-route — vertel wat je voor ogen hebt, dan delen we wat we van Visit Bonaire en Bonaire Cruisers hebben geleerd.</p>
        <div class="flex justify-center">
          <ArrowButton href="/nl/contact/" variant="primary">Plan een gesprek</ArrowButton>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
