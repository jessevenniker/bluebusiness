---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/shared/Container.astro';
import MonoEyebrow from '../../../components/shared/MonoEyebrow.astro';
import ArrowButton from '../../../components/shared/ArrowButton.astro';

const baseUrl = Astro.site ? Astro.site.origin : 'https://bluebusiness.nl';
const schema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'GAST',
  operatingSystem: 'iOS, Android',
  applicationCategory: 'TravelApplication',
  url: `${baseUrl}/nl/cases/gast/`,
  inLanguage: 'nl',
  publisher: { '@id': `${baseUrl}/#organization` },
  about: 'White-label gast-app voor vakantieparken en hospitality — gebouwd op het Medewerker.app-platform, live bij Hof van Saksen en Roompot.',
};

const clients = [
  { name: 'Hof van Saksen', sector: 'Vakantieparken' },
  { name: 'Roompot', sector: 'Vakantieparken' },
];
---

<BaseLayout
  title="GAST — gast-app voor vakantieparken | Blue Business"
  description="GAST is een white-label gast-app voor vakantieparken en hospitality, gebouwd op het Medewerker.app-platform door Blue Business. Live bij Hof van Saksen en Roompot."
  canonicalPath="/nl/cases/gast/"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />

  <section class="pt-[140px] md:pt-[180px] pb-16">
    <Container>
      <nav aria-label="Breadcrumb" class="mb-10 font-mono text-[12px] text-fg-faint">
        <ol class="flex flex-wrap items-center gap-2">
          <li><a href="/nl/" class="hover:text-accent-hi">Home</a></li>
          <li>/</li>
          <li><a href="/nl/cases/" class="hover:text-accent-hi">Cases</a></li>
          <li>/</li>
          <li class="text-fg-dim">GAST</li>
        </ol>
      </nav>

      <MonoEyebrow text="// hospitality" tone="accent-hi" class="mb-6 block" />
      <h1 class="text-h1 font-medium max-w-[20ch]" style="letter-spacing: var(--tracking-tight); line-height: 1.02;">
        <span class="block text-fg">GAST — gast-app op</span>
        <span class="block text-accent">hetzelfde platform.</span>
      </h1>
      <p class="text-lead text-fg-dim mt-8 max-w-[60ch]">
        White-label gast-app voor vakantieparken en hospitality-bedrijven. GAST draait op hetzelfde platform als Medewerker.app, maar dan gericht op de gasten in plaats van het personeel — van check-in tot kamer-info tot lokale tips, in een eigen merk-jas per park.
      </p>
    </Container>
  </section>

  <section class="py-16 md:py-20 border-t border-[var(--color-accent-line)]">
    <Container>
      <h2 class="font-mono text-[12px] text-accent-hi uppercase tracking-[0.04em] mb-8">Onze opdrachtgevers</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {clients.map((c) => (
          <div class="p-6 rounded-[14px] bg-[var(--color-bg-elevated)] border border-[var(--color-border)]">
            <p class="text-[18px] font-medium text-fg mb-2">{c.name}</p>
            <p class="font-mono text-[12px] text-fg-faint uppercase tracking-[0.04em]">{c.sector}</p>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <section class="py-20 md:py-24">
    <Container size="narrow">
      <h2 class="text-h3 font-medium text-fg mb-4" style="letter-spacing: var(--tracking-snug);">Wat we hebben gebouwd</h2>
      <p class="text-[16px] text-fg-dim mb-6" style="line-height: 1.7;">
        Een native iOS- en Android-app die gasten van een vakantiepark digitaal door hun verblijf leidt — zonder dat de receptie elke vraag persoonlijk hoeft te beantwoorden. Boekingsdetails, wifi-codes, openingstijden, restaurant-menu's, lokale tips en activiteiten zitten allemaal één tap weg, in de huisstijl van het park.
      </p>
      <p class="text-[16px] text-fg-dim" style="line-height: 1.7;">
        Doordat GAST en Medewerker.app op één codebase draaien, profiteren beide producten van dezelfde release-cycli, dezelfde stabiliteit en dezelfde admin-tools. Voor parken als Hof van Saksen en Roompot betekent dat: één leverancier, twee apps, één rekening — en doorlopend onderhoud op de échte mobiele werkdag van zowel medewerker als gast.
      </p>

      <h2 class="text-h3 font-medium text-fg mt-12 mb-4" style="letter-spacing: var(--tracking-snug);">Belangrijkste features</h2>
      <ul class="space-y-3 text-[15px] text-fg-dim" role="list">
        <li class="flex gap-3"><span class="text-accent mt-[6px]">→</span> Persoonlijke welkomst en boekingsoverzicht per gast</li>
        <li class="flex gap-3"><span class="text-accent mt-[6px]">→</span> Park-info, plattegrond, openingstijden en huisregels</li>
        <li class="flex gap-3"><span class="text-accent mt-[6px]">→</span> Activiteiten-agenda en in-app reserveringen voor wellness, restaurants, taxi</li>
        <li class="flex gap-3"><span class="text-accent mt-[6px]">→</span> Lokale tips en partner-deals in de omgeving van het park</li>
        <li class="flex gap-3"><span class="text-accent mt-[6px]">→</span> Push-notificaties voor weer-updates, bezorg-berichten of dagprogramma</li>
        <li class="flex gap-3"><span class="text-accent mt-[6px]">→</span> White-label per park — eigen logo, kleuren, content en talen</li>
      </ul>

      <h2 class="text-h3 font-medium text-fg mt-12 mb-4" style="letter-spacing: var(--tracking-snug);">Tech-stack</h2>
      <ul class="space-y-3 text-[15px] text-fg-dim" role="list">
        <li class="flex gap-3"><span class="text-accent mt-[6px]">→</span> Native iOS (Swift, SwiftUI) en native Android (Kotlin, Compose)</li>
        <li class="flex gap-3"><span class="text-accent mt-[6px]">→</span> Gedeeld backend met Medewerker.app — multi-tenant, white-label-baar</li>
        <li class="flex gap-3"><span class="text-accent mt-[6px]">→</span> Web-admin voor parkbeheer: content, doelgroepen, push-campagnes</li>
        <li class="flex gap-3"><span class="text-accent mt-[6px]">→</span> Koppelingen met PMS en boekingssystemen voor automatische gast-data</li>
      </ul>
    </Container>
  </section>

  <section class="py-24 md:py-32 border-t border-[var(--color-accent-line)] relative overflow-hidden">
    <div aria-hidden="true" class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse at center, rgba(59, 130, 246, 0.08) 0%, transparent 60%);"></div>
    <Container size="narrow">
      <div class="text-center relative">
        <MonoEyebrow text="// Iets vergelijkbaars bouwen?" tone="dim" class="mb-6 block" />
        <h2 class="text-h2 font-medium mb-6" style="letter-spacing: var(--tracking-tight); line-height: 1.08;">
          <span class="block text-fg">Hospitality-apps die</span>
          <span class="block text-accent">gasten dagelijks openen.</span>
        </h2>
        <p class="text-lead text-fg-dim mb-10 max-w-[50ch] mx-auto">Vakantiepark, hotelketen of campingbedrijf? GAST is bewezen technologie — we kunnen 'm zo aanpassen aan jouw gasten en jouw merk.</p>
        <div class="flex justify-center">
          <ArrowButton href="/nl/contact/" variant="primary">Plan een gesprek</ArrowButton>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
