---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/shared/Container.astro';
import MonoEyebrow from '../../../components/shared/MonoEyebrow.astro';
import { getCurrentLocale, routeMap } from '../../../i18n/routes';
import { getContent } from '../../../i18n/content';

const locale = getCurrentLocale(Astro.url.pathname);
const content = getContent(locale);
const t = content.casesPage;
const r = routeMap[locale];
const cases = content.home.cases.items;

function cleanTitle(s: string) { return s.replace(/^\[TBD\]\s*/, ''); }

const letterById: Record<string, string> = {
  'bonaire-app': 'B',
  'bonaire-cruisers': 'C',
  'medewerker-app': 'M',
  'gast': 'G',
  'run2forty2': 'R',
};
---

<BaseLayout
  title={t.meta.title}
  description={t.meta.description}
  canonicalPath={r.cases}
  breadcrumbs={[{ name: 'Home', path: '/nl/' }, { name: 'Cases', path: '/nl/cases/' }]}
>
  <section class="pt-[140px] md:pt-[180px] pb-16">
    <Container>
      <MonoEyebrow text={t.eyebrow} tone="accent-hi" class="mb-5 block" />
      <h1 class="text-h1 font-medium max-w-[18ch]" style="letter-spacing: var(--tracking-tight); line-height: 1.02;">
        <span class="block text-fg">{t.h1Line1}</span>
        <span class="block text-accent">{t.h1Line2}</span>
      </h1>
      <p class="text-lead text-fg-dim mt-8 max-w-[60ch]">{t.lead}</p>
    </Container>
  </section>

  <section class="pb-24 md:pb-32">
    <Container>
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-4" role="list">
        {cases.map((c) => (
          <li>
            <a href={`${r.cases}${c.id}/`} class="case-card block h-full p-7 rounded-[14px] bg-[var(--color-bg-elevated)] border border-[var(--color-border)] transition-all duration-[240ms]">
              <div
                class="h-[200px] rounded-[10px] mb-6 relative overflow-hidden"
                style={`background: radial-gradient(ellipse at center, ${c.accentColor}30 0%, ${c.accentColor}08 70%);`}
                aria-hidden="true"
              >
                {c.iconSrc ? (
                  <div class="absolute inset-0 p-8 flex items-center justify-center">
                    <div class="w-full h-full max-w-[300px] max-h-[130px] bg-white rounded-[14px] shadow-[0_20px_50px_-15px_rgba(0,0,0,0.5)] flex items-center justify-center p-6">
                      <img src={c.iconSrc} alt="" class="max-w-full max-h-full object-contain" loading="lazy" />
                    </div>
                  </div>
                ) : (
                  <div class="absolute inset-0 flex items-center justify-center">
                    <div class="w-[72px] h-[72px] rounded-[18px] bg-[var(--color-bg)] border border-[var(--color-accent-line)] flex items-center justify-center">
                      <span class="font-mono text-[18px] font-medium" style={`color: ${c.accentColor};`}>
                        {letterById[c.id] ?? '·'}
                      </span>
                    </div>
                  </div>
                )}
              </div>
              <span class="font-mono text-[12px] text-accent-hi mb-3 block">{c.label}</span>
              <h2 class="text-[22px] font-medium text-fg mb-3" style="letter-spacing: var(--tracking-snug); line-height: 1.2;">
                {cleanTitle(c.title)}
              </h2>
              <p class="text-[15px] text-fg-dim mb-5" style="line-height: 1.6;">{c.body}</p>
              <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-[var(--color-accent-line)] bg-[var(--color-accent)]/[0.06] font-mono text-[12px] text-accent-hi">
                {c.datapoint}
              </span>
            </a>
          </li>
        ))}
      </ul>
    </Container>
  </section>
</BaseLayout>

<style>
  .case-card:hover { border-color: var(--color-accent-line); transform: translateY(-2px); }
</style>
