{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": true,
  "redirects": [
    { "source": "/", "destination": "/nl/", "permanent": false },
    { "source": "/index.html", "destination": "/nl/", "permanent": true },
    { "source": "/privacy-policy/", "destination": "/nl/privacy/", "permanent": true },
    { "source": "/index/", "destination": "/nl/", "permanent": true },
    { "source": "/diensten.html", "destination": "/nl/diensten/", "permanent": true },
    { "source": "/projecten.html", "destination": "/nl/cases/", "permanent": true },
    { "source": "/projects.html", "destination": "/nl/cases/", "permanent": true },
    { "source": "/bonaire-app.html", "destination": "/nl/cases/bonaire-app/", "permanent": true },
    { "source": "/medewerker-app.html", "destination": "/nl/cases/medewerker-app/", "permanent": true },
    { "source": "/gast.html", "destination": "/nl/cases/gast/", "permanent": true },
    { "source": "/contact.html", "destination": "/nl/contact/", "permanent": true },
    { "source": "/over.html", "destination": "/nl/over-ons/", "permanent": true },
    { "source": "/over-ons.html", "destination": "/nl/over-ons/", "permanent": true },
    { "source": "/privacy-policy.html", "destination": "/nl/privacy/", "permanent": true },
    { "source": "/privacy.html", "destination": "/nl/privacy/", "permanent": true },
    { "source": "/terms.html", "destination": "/nl/voorwaarden/", "permanent": true },
    { "source": "/voorwaarden.html", "destination": "/nl/voorwaarden/", "permanent": true },
    { "source": "/diensten/", "destination": "/nl/diensten/", "permanent": true },
    { "source": "/projecten/", "destination": "/nl/cases/", "permanent": true },
    { "source": "/cases/", "destination": "/nl/cases/", "permanent": true },
    { "source": "/contact/", "destination": "/nl/contact/", "permanent": true },
    { "source": "/over-ons/", "destination": "/nl/over-ons/", "permanent": true },
    { "source": "/privacy/", "destination": "/nl/privacy/", "permanent": true },
    { "source": "/voorwaarden/", "destination": "/nl/voorwaarden/", "permanent": true },
    { "source": "/services/", "destination": "/en/services/", "permanent": true },
    { "source": "/work/", "destination": "/en/cases/", "permanent": true },
    { "source": "/about/", "destination": "/en/about/", "permanent": true },
    { "source": "/terms/", "destination": "/en/terms/", "permanent": true },
    { "source": "/bonaire-app/", "destination": "/nl/cases/bonaire-app/", "permanent": true },
    { "source": "/medewerker-app/", "destination": "/nl/cases/medewerker-app/", "permanent": true },
    { "source": "/gast/", "destination": "/nl/cases/gast/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/_astro/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/llms.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    }
  ]
}
